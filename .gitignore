*.vsix
node_modules/

# Built third-party libs — produced by `npm run build:vendor` from
# devDependencies. Source-of-truth lives in package.json. Keep the
# build script tracked; ignore everything else in lib/.
lib/*
!lib/build-vendor.mjs

# Auto-generated by build:vendor from each bundled dependency's LICENSE
# file. Lands in the vsix at packaging time; not tracked in git.
THIRD-PARTY-LICENSES.md
