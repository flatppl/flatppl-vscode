{
  "scopeName": "markdown.flatppl.codeblock",
  "injectionSelector": "L:text.html.markdown",
  "patterns": [
    { "include": "#fenced_code_block_flatppl" }
  ],
  "repository": {
    "fenced_code_block_flatppl": {
      "begin": "(^|\\G)(\\s*)(`{3,}|~{3,})\\s*(?i:(flatppl)(\\s+[^`~]*)?$)",
      "beginCaptures": {
        "3": { "name": "punctuation.definition.markdown" },
        "5": { "name": "fenced_code.block.language" },
        "6": { "name": "fenced_code.block.language.attributes" }
      },
      "end": "(^|\\G)(\\2|\\s{0,3})(\\3)\\s*$",
      "endCaptures": {
        "3": { "name": "punctuation.definition.markdown" }
      },
      "name": "markup.fenced_code.block.markdown",
      "patterns": [
        {
          "begin": "(^|\\G)(\\s*)(.*)",
          "contentName": "meta.embedded.block.flatppl",
          "patterns": [
            { "include": "source.flatppl" }
          ],
          "while": "(^|\\G)(?!\\s*([`~]{3,})\\s*$)"
        }
      ]
    }
  }
}
