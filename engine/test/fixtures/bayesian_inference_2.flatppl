# A simple Bayesian example using structural disintegration: build the joint
# distribution first, then disintegrate to extract the forward kernel and prior.
# Same model as bayesian_inference.flatppl, expressed by disintegration of the
# joint instead of separate prior/model reifications.

# Stochastic nodes
theta1 = draw(Normal(mu = 0.0, sigma = 1.0))
theta2 = draw(Exponential(rate = 1.0))

f_a = functionof(5.0 * _par_, par = _par_)
f_b = fn(abs(_) * _)

# Deterministic transform
a = f_a(par = theta1)
b = f_b(theta1, theta2)

# IID observations from the forward model
obs = draw(iid(Normal(mu = a, sigma = b), 10))

# Joint distribution over parameters and observations
joint_model = lawof(record(theta1 = theta1, theta2 = theta2, obs = obs))

# Structural disintegration
forward_kernel, prior = disintegrate(["obs"], joint_model)

# Observed data
observed_data = [1.2, 3.4, 5.1, 2.8, 4.0, 3.7, 5.5, 2.1, 4.3, 3.9]

# Likelihood
L = likelihoodof(forward_kernel, record(obs = observed_data))

# Non-normalized posterior
posterior = bayesupdate(L, prior)
