# Complex disintegration test fixture.
#
# Exercises a mix of patterns the engine should handle (Tier 1) and a few
# that should fall back gracefully.

# ---- Module-level inputs and parameters ----

mu = elementof(reals)
sigma = elementof(posreals)

# ---- Stochastic chain ----

theta1 = draw(Normal(mu = mu, sigma = sigma))
theta2 = draw(Exponential(rate = 1.0))
shift = theta1 + theta2

obs1 = draw(Normal(mu = shift, sigma = 1.0))
obs2 = draw(Normal(mu = theta1, sigma = sigma))

# ---- Joint with parametric ancestors ----
#
# theta1 depends on mu and sigma (parametric); the resulting joint is a
# parametric measure. Disintegration produces a kernel and prior that
# remain parametric in mu, sigma.

joint_with_inputs = lawof(
    record(theta1 = theta1, theta2 = theta2, obs1 = obs1, obs2 = obs2))

# Single-field selector (string form). Kernel: obs1; prior: theta1, theta2, obs2.
fk_a, pr_a = disintegrate("obs1", joint_with_inputs)

# Multi-field selector. Kernel: obs1, obs2; prior: theta1, theta2.
fk_b, pr_b = disintegrate(["obs1", "obs2"], joint_with_inputs)

# ---- Joint without external inputs ----

joint_pure = lawof(record(theta1 = theta1, obs1 = obs1))
fk_c, pr_c = disintegrate("obs1", joint_pure)

# ---- Fall-back case: joint constructed via measure-algebra `chain` ----
#
# The structure isn't statically resolvable to a record-of-fields, so the
# engine should leave the disintegration result as a plain dependency on
# the joint binding (no synthesized kernel/prior view).

prior_m = Normal(mu = 0.0, sigma = 1.0)
fwd_k = Normal(mu = mu, sigma = 1.0)
joint_chained = chain(prior_m, fwd_k)
fk_d, pr_d = disintegrate("x", joint_chained)
