# ===== Module imports =====

hepphys = standard_module("particle-physics", "0.1")

# ===== Broadcasted operations =====

bcadd = broadcasted(add)
bcmul = broadcasted(mul)

# ===== Nominal templates and uncertainties =====
sig = [12.0, 11.0]
bkg = [50.0, 52.0]
dbkg = [3.0, 7.0]

# ===== Observed data =====
obs_data = [51.0, 48.0]

# ===== Free parameters =====
mu = elementof(nonnegreals)
gamma = elementof(cartpow(posreals, 2))

# ===== Observation draws =====
expected = bcadd(bcmul(mu, sig), bcmul(gamma, bkg))
obs = draw(broadcast(Poisson, expected))

# ===== Auxiliary draws (constraint measurements) =====
tau = broadcast(pow, broadcast(divide, bkg, dbkg), 2)
aux = draw(broadcast(hepphys.ContinuedPoisson, bcmul(gamma, tau)))

# ===== Likelihoods =====
L_obs = likelihoodof(lawof(obs), obs_data)
L_aux = likelihoodof(lawof(aux), tau)
L = joint_likelihood(L_obs, L_aux)
