{
  "name": "flatppl-js",
  "private": true,
  "version": "0.0.0",
  "description": "JavaScript ecosystem for FlatPPL — engine, VS Code extension, future LSP and web preview.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/flatppl/flatppl-js"
  },
  "workspaces": [
    "packages/*"
  ],
  "scripts": {
    "test": "npm test --workspaces --if-present",
    "build:vendor": "npm run --workspace=packages/vscode-extension build:vendor",
    "watch:vendor": "npm run --workspace=packages/vscode-extension watch:vendor"
  },
  "engines": {
    "node": ">=18"
  }
}
