{
  "name": "@flatppl/viewer",
  "version": "0.1.0",
  "description": "Browser-loadable FlatPPL DAG + plot visualization. Host-agnostic; depends on cytoscape, echarts and the FlatPPL engine bundle. Embedded by the VS Code extension and intended for online docs / standalone web previews.",
  "license": "MIT",
  "private": true,
  "main": "./src/viewer.js",
  "files": [
    "src/",
    "README.md",
    "LICENSE"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/flatppl/flatppl-js",
    "directory": "packages/viewer"
  },
  "scripts": {
    "build": "node ./build.mjs",
    "watch": "node ./build.mjs --watch",
    "serve": "node ./serve.mjs"
  },
  "devDependencies": {
    "@flatppl/engine": "*",
    "esbuild": "^0.28.0",
    "cytoscape": "^3.30.4",
    "@dagrejs/dagre": "^3.0.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-bubblesets": "^4.1.0",
    "cytoscape-layers": "^3.1.0",
    "echarts": "^6.0.0"
  },
  "engines": {
    "node": ">=18"
  },
  "keywords": [
    "flatppl",
    "visualization",
    "dag",
    "cytoscape",
    "echarts"
  ]
}
