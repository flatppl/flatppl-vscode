{
  "name": "flatppl",
  "displayName": "FlatPPL",
  "description": "Syntax highlighting and DAG visualization for the FlatPPL probabilistic language",
  "version": "0.2.0",
  "publisher": "flatppl",
  "license": "MIT",
  "icon": "icon.png",
  "repository": {
    "type": "git",
    "url": "https://github.com/flatppl/flatppl-js",
    "directory": "packages/vscode-extension"
  },
  "engines": {
    "vscode": "^1.75.0"
  },
  "main": "./extension.js",
  "scripts": {
    "build:vendor": "node ./build-vendor.mjs",
    "watch:vendor": "node ./build-vendor.mjs --watch"
  },
  "devDependencies": {
    "@flatppl/engine": "*",
    "esbuild": "^0.28.0",
    "cytoscape": "^3.30.4",
    "@dagrejs/dagre": "^3.0.0",
    "cytoscape-dagre": "^2.5.0",
    "cytoscape-bubblesets": "^4.1.0",
    "cytoscape-layers": "^3.1.0",
    "echarts": "^6.0.0"
  },
  "activationEvents": [
    "onLanguage:flatppl"
  ],
  "categories": [
    "Programming Languages",
    "Visualization"
  ],
  "contributes": {
    "commands": [
      {
        "command": "flatppl.visualize",
        "title": "FlatPPL: Visualize Binding",
        "icon": {
          "light": "./media/visualize-binding-light.svg",
          "dark":  "./media/visualize-binding-dark.svg"
        }
      },
      {
        "command": "flatppl.visualizeModule",
        "title": "FlatPPL: Visualize Module",
        "icon": {
          "light": "./media/visualize-module-light.svg",
          "dark":  "./media/visualize-module-dark.svg"
        }
      },
      {
        "command": "flatppl.visualizeEmbedded",
        "title": "FlatPPL: Visualize Embedded Model"
      }
    ],
    "menus": {
      "commandPalette": [
        {
          "command": "flatppl.visualize",
          "when": "editorLangId == flatppl"
        },
        {
          "command": "flatppl.visualizeModule",
          "when": "editorLangId == flatppl"
        },
        {
          "command": "flatppl.visualizeEmbedded",
          "when": "editorLangId == python || editorLangId == julia"
        }
      ],
      "editor/context": [
        {
          "command": "flatppl.visualizeEmbedded",
          "when": "editorLangId == python || editorLangId == julia",
          "group": "navigation@9"
        }
      ],
      "editor/title": [
        {
          "command": "flatppl.visualize",
          "when": "editorLangId == flatppl",
          "group": "navigation@1"
        },
        {
          "command": "flatppl.visualizeModule",
          "when": "editorLangId == flatppl",
          "group": "navigation@2"
        }
      ]
    },
    "languages": [
      {
        "id": "flatppl",
        "aliases": [
          "FlatPPL",
          "flatppl"
        ],
        "extensions": [
          ".flatppl"
        ],
        "configuration": "./language-configuration.json"
      }
    ],
    "grammars": [
      {
        "language": "flatppl",
        "scopeName": "source.flatppl",
        "path": "./grammars/textmate/flatppl.tmLanguage.json"
      },
      {
        "scopeName": "markdown.flatppl.codeblock",
        "path": "./grammars/textmate/flatppl-markdown.tmLanguage.json",
        "injectTo": [
          "text.html.markdown"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.flatppl": "flatppl"
        }
      },
      {
        "scopeName": "flatppl.embedded.python",
        "path": "./grammars/textmate/flatppl-python.tmLanguage.json",
        "injectTo": [
          "source.python"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.flatppl": "flatppl"
        }
      },
      {
        "scopeName": "flatppl.embedded.julia",
        "path": "./grammars/textmate/flatppl-julia.tmLanguage.json",
        "injectTo": [
          "source.julia"
        ],
        "embeddedLanguages": {
          "meta.embedded.block.flatppl": "flatppl"
        }
      }
    ],
    "configuration": {
      "title": "FlatPPL",
      "properties": {
        "flatppl.visualization.sampleCount": {
          "type": "integer",
          "default": 100000,
          "minimum": 100,
          "maximum": 10000000,
          "markdownDescription": "Number of Monte Carlo samples drawn per binding when the visualizer renders a histogram. Higher values give smoother plots; lower values are faster. Changing this clears the visualizer's sample cache."
        },
        "flatppl.visualization.dagNavigationHistoryCap": {
          "type": "integer",
          "default": 1000,
          "minimum": 0,
          "maximum": 100000,
          "markdownDescription": "Maximum number of entries kept in the visualizer's DAG navigation history (the back-button stack). Older entries are dropped when the cap is reached. Each entry is a small sub-DAG snapshot (~few KB)."
        },
        "flatppl.visualization.truncateRejectionBudget": {
          "type": "integer",
          "default": 1000,
          "minimum": 1,
          "maximum": 1000000,
          "markdownDescription": "Per-atom rejection-redraw budget for `truncate(M, S)` when the parent measure isn't CDF-invertible. The visualizer redraws from the underlying distribution up to this many times per atom before giving up and emitting `NaN`. Higher values trade compute for less ESS loss on tightly-truncated measures; lower values keep large-N plots responsive. Changing this clears the visualizer's sample cache."
        }
      }
    }
  },
  "cspell": {
    "version": "0.2",
    "dictionaryDefinitions": [
      {
        "name": "flatppl",
        "path": "./grammars/cspell/flatppl-words.txt",
        "description": "FlatPPL builtins / keywords (synced from flatppl-grammars)"
      }
    ],
    "languageSettings": [
      { "languageId": "flatppl", "dictionaries": ["flatppl"] },
      { "languageId": "python", "dictionaries": ["flatppl"] },
      { "languageId": "julia", "dictionaries": ["flatppl"] }
    ]
  }
}
